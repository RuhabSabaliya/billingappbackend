generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(uuid())
  firebaseUid String   @unique @map("firebase_uid")
  email       String   @unique
  role        String   @default("staff") // 'admin' | 'staff'
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  isActive    Boolean  @default(true) @map("is_active")

  categories  Category[]
  products    Product[]
  customers   Customer[]
  bills       Bill[]

  @@map("users")
}

model Category {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  name        String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  isActive    Boolean  @default(true) @map("is_active")

  user        User     @relation(fields: [userId], references: [id])
  products    Product[]

  @@index([userId])
  @@unique([userId, name])
  @@map("categories")
}

model Product {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  categoryId  String   @map("category_id")
  name        String
  price       Decimal  @db.Decimal(10, 2)
  stock       Int      @default(0)
  barcode     String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  isActive    Boolean  @default(true) @map("is_active")

  user        User     @relation(fields: [userId], references: [id])
  category    Category @relation(fields: [categoryId], references: [id])
  billItems   BillItem[]

  @@index([userId])
  @@index([categoryId])
  @@unique([userId, barcode])
  @@map("products")
}

model Customer {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  name        String?
  phone       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  isActive    Boolean  @default(true) @map("is_active")

  user        User     @relation(fields: [userId], references: [id])
  bills       Bill[]

  @@index([userId])
  @@unique([userId, phone])
  @@map("customers")
}

model Bill {
  id             String    @id @default(uuid())
  billNumber     String    @unique @map("bill_number")
  userId         String    @map("user_id")
  customerId     String?   @map("customer_id")
  totalAmount    Decimal   @db.Decimal(10, 2) @map("total_amount")
  taxAmount      Decimal   @default(0) @db.Decimal(10, 2) @map("tax_amount")
  discountAmount Decimal   @default(0) @db.Decimal(10, 2) @map("discount_amount")
  status         String    @default("COMPLETED") // 'COMPLETED' | 'SYNCED'
  createdAt      DateTime  @default(now()) @map("created_at")

  user           User      @relation(fields: [userId], references: [id])
  customer       Customer? @relation(fields: [customerId], references: [id])
  items          BillItem[]

  @@index([userId])
  @@index([customerId])
  @@map("bills")
}

model BillItem {
  id             String   @id @default(uuid())
  billId         String   @map("bill_id")
  productId      String?  @map("product_id") // Nullable if product is deleted later
  productName    String   @map("product_name") // Snapshot of name at time of sale
  price          Decimal  @db.Decimal(10, 2) // Snapshot of price at time of sale
  quantity       Int

  bill           Bill     @relation(fields: [billId], references: [id])
  product        Product? @relation(fields: [productId], references: [id])

  @@index([billId])
  @@index([productId])
  @@map("bill_items")
}
